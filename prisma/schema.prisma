// MODIFIED: 增加 driverAdapters 以支持 Cloudflare D1
generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL") // 保持不变，本地 seed 脚本仍然需要
}

model KnowledgePoint {
  id         String   @id
  subject    String
  grade      String
  module     String
  pointName  String
  weight     Float
  difficulty Int
  content    String
  
  // 删除了 SQLite 不支持的 parentIds String[]
  // 使用 Prisma 官方标准的多对多自关联写法
  parents    KnowledgePoint[] @relation("KnowledgeHierarchy")
  children   KnowledgePoint[] @relation("KnowledgeHierarchy")
}